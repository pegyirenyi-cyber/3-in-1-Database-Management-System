# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PAYSTACK INTEGRATION KEYS
# Secret key for server-side Paystack API initialization & webhook verification
PAYSTACK_SECRET_KEY=
# Public key for client-side Paystack payment popup
VITE_PAYSTACK_PUBLIC_KEY=

# TWILIO INTEGRATION KEYS
# SID for outbound Twilio SMS API
TWILIO_ACCOUNT_SID=
# Auth token for Twilio security header basic auth
TWILIO_AUTH_TOKEN=
# Valid Twilio purchased mobile phone number in E.164 format
TWILIO_FROM_NUMBER=

