{
  "entities": {
    "SchoolInfo": {
      "title": "SchoolInfo",
      "description": "Profile information for the school setup",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "motto": { "type": "string" },
        "logoUrl": { "type": "string" },
        "schoolNumber": { "type": "string" },
        "emisCode": { "type": "string" },
        "gpsAddress": { "type": "string" },
        "schoolType": { "type": "string", "enum": ["Public", "Private"] },
        "headteacherName": { "type": "string" },
        "telephone": { "type": "string" },
        "email": { "type": "string" },
        "qualifications": { "type": "string" },
        "highestAcademicQualifications": { "type": "string" },
        "district": { "type": "string" },
        "circuit": { "type": "string" },
        "paystackPublicKey": { "type": "string" },
        "paystackSecretKey": { "type": "string" },
        "paystackMode": { "type": "string" },
        "twilioAccountSid": { "type": "string" },
        "twilioAuthToken": { "type": "string" },
        "twilioFromNumber": { "type": "string" },
        "twilioEnabled": { "type": "boolean" },
        "smsBalance": { "type": "number" },
        "smsSenderId": { "type": "string" }
      },
      "required": ["id", "name", "schoolType", "headteacherName"]
    },
    "Student": {
      "title": "Student",
      "description": "Profile information for an enrolled student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "middleName": { "type": "string" },
        "lastName": { "type": "string" },
        "class": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dateOfBirth": { "type": "string" },
        "placeOfBirth": { "type": "string" },
        "status": { "type": "string", "enum": ["Day", "Boarder"] },
        "section": { "type": "string", "enum": ["Faith", "Harmony", "Humility", "Peace"] },
        "nationality": { "type": "string" },
        "guardianName": { "type": "string" },
        "guardianTelephone": { "type": "string" },
        "guardianOccupation": { "type": "string" },
        "residentialAddress": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "class", "gender", "dateOfBirth", "section", "status"]
    },
    "Teacher": {
      "title": "Teacher",
      "description": "Profile information for a school teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "middleName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dateOfBirth": { "type": "string" },
        "placeOfBirth": { "type": "string" },
        "subjectsTaught": { "type": "string" },
        "professionalQualifications": { "type": "string" },
        "highestAcademicQualifications": { "type": "string" },
        "rank": { "type": "string" },
        "dateOfFirstAppointment": { "type": "string" },
        "dateOfPostingToCurrentStation": { "type": "string" },
        "staffId": { "type": "string" },
        "ntcNumber": { "type": "string" },
        "ssnitNumber": { "type": "string" },
        "district": { "type": "string" },
        "circuit": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "gender", "staffId", "rank"]
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "Daily attendance mark for a student",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "class": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Holiday", "Absent"] }
      },
      "required": ["id", "date", "studentId", "class", "status"]
    },
    "StudentAssessment": {
      "title": "StudentAssessment",
      "description": "Academic scores and remarks for a student in a subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "class": { "type": "string" },
        "academicYear": { "type": "string" },
        "term": { "type": "string" },
        "subject": { "type": "string" },
        "exercises": { "type": "array" },
        "tests": { "type": "array" },
        "projectWork": { "type": "number" },
        "groupWork": { "type": "number" },
        "classScoreTotal": { "type": "number" },
        "classScore50": { "type": "number" },
        "examScore100": { "type": "number" },
        "examScore50": { "type": "number" },
        "totalScore": { "type": "number" },
        "gradeLevel": { "type": "string", "enum": ["L1", "L2", "L3", "L4", "L5"] },
        "remarks": { "type": "string" },
        "position": { "type": "number" },
        "teacherRemarks": { "type": "string" }
      },
      "required": ["id", "studentId", "class", "academicYear", "term", "subject", "totalScore", "gradeLevel"]
    },
    "UserAccount": {
      "title": "UserAccount",
      "description": "Role-assigned user profile mapping to login state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Admin", "Headteacher"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "StudentFeeBill": {
      "title": "StudentFeeBill",
      "description": "Record of student fee bills and historical payment installments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "class": { "type": "string" },
        "academicYear": { "type": "string" },
        "term": { "type": "string" },
        "schoolFees": { "type": "number" },
        "utilityBill": { "type": "number" },
        "sportsFees": { "type": "number" },
        "ptaDues": { "type": "number" },
        "otherFee": { "type": "number" },
        "otherFeeDescription": { "type": "string" },
        "payments": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "studentId", "class", "academicYear", "term"]
    },
    "PaystackPayment": {
      "title": "PaystackPayment",
      "description": "Log of successful online transactions processed via the Paystack gateway",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reference": { "type": "string" },
        "studentId": { "type": "string" },
        "billId": { "type": "string" },
        "component": { "type": "string" },
        "amount": { "type": "number" },
        "academicYear": { "type": "string" },
        "term": { "type": "string" },
        "status": { "type": "string" },
        "paidAt": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "reference", "amount", "status"]
    },
    "StaffAttendanceRecord": {
      "title": "StaffAttendanceRecord",
      "description": "Daily attendance mark and times for a teacher/staff member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "status": { "type": "string", "enum": ["Present", "Absent", "On Leave", "Unmarked"] },
        "arrivalTime": { "type": "string" },
        "departureTime": { "type": "string" },
        "remarks": { "type": "string" }
      },
      "required": ["id", "date", "teacherId", "teacherName", "status"]
    },
    "SyncEvent": {
      "title": "SyncEvent",
      "description": "Real-time sync event between teacher and headteacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "recipientId": { "type": "string" },
        "type": { "type": "string", "enum": ["AssessmentUpdate", "AssignmentNotification"] },
        "payload": { "type": "object" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "senderId", "recipientId", "type", "createdAt"]
    },
    "AcademicCalendarConfig": {
      "title": "AcademicCalendarConfig",
      "description": "System-wide academic calendar active configuration",
      "type": "object",
      "properties": {
        "activeAcademicYear": { "type": "string" },
        "activeTerm": { "type": "string" },
        "years": { "type": "object" }
      },
      "required": ["activeAcademicYear", "activeTerm"]
    },
    "EmisData": {
      "title": "EmisData",
      "description": "Ministry of Education / GES standard aligned EMIS school census metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "academicYear": { "type": "string" },
        "censusDate": { "type": "string" },
        "emisCode": { "type": "string" },
        "circuitName": { "type": "string" },
        "districtName": { "type": "string" },
        "regionName": { "type": "string" },
        "schoolType": { "type": "string", "enum": ["Public", "Private"] },
        "religiousAffiliation": { "type": "string" },
        "dayBoarding": { "type": "string" },
        "multiGradeTeaching": { "type": "boolean" },
        "boysEnrolled": { "type": "object" },
        "girlsEnrolled": { "type": "object" },
        "repeatersBoys": { "type": "object" },
        "repeatersGirls": { "type": "object" },
        "disabledBoys": { "type": "object" },
        "disabledGirls": { "type": "object" },
        "permanentClassrooms": { "type": "number" },
        "temporaryClassrooms": { "type": "number" },
        "classroomsUnderTrees": { "type": "number" },
        "drinkingWaterSource": { "type": "string" },
        "toiletType": { "type": "string" },
        "toiletBoothsBoys": { "type": "number" },
        "toiletBoothsGirls": { "type": "number" },
        "hasElectricity": { "type": "boolean" },
        "electricitySource": { "type": "string" },
        "hasFunctionalIctLab": { "type": "boolean" },
        "totalWorkingComputers": { "type": "number" },
        "englishTextbooks": { "type": "number" },
        "mathTextbooks": { "type": "number" },
        "scienceTextbooks": { "type": "number" },
        "socialStudiesTextbooks": { "type": "number" },
        "trainedMaleTeachers": { "type": "number" },
        "trainedFemaleTeachers": { "type": "number" },
        "untrainedMaleTeachers": { "type": "number" },
        "untrainedFemaleTeachers": { "type": "number" },
        "nonTeachingMaleStaff": { "type": "number" },
        "nonTeachingFemaleStaff": { "type": "number" },
        "locationType": { "type": "string" },
        "yearFounded": { "type": "number" },
        "isSchoolFeedingBeneficiary": { "type": "boolean" },
        "studentsFedDailyCount": { "type": "number" },
        "hasSeparateStaffToilets": { "type": "boolean" },
        "hasHandwashingStations": { "type": "boolean" },
        "hasFunctionalSickBay": { "type": "boolean" },
        "hasActiveSmc": { "type": "boolean" },
        "hasActivePta": { "type": "boolean" },
        "ptaMeetingsHeldCount": { "type": "number" },
        "hasFunctionalLibrary": { "type": "boolean" },
        "totalLibraryBooks": { "type": "number" },
        "hasScienceKit": { "type": "boolean" },
        "isCompoundFenced": { "type": "boolean" },
        "hasSecurityGuard": { "type": "boolean" },
        "targetCommunityPopulation": { "type": "number" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "academicYear", "censusDate", "emisCode"]
    }
  },
  "firestore": {
    "/schools/{schoolId}": {
      "schema": "SchoolInfo",
      "description": "Collection hosting general school metadata"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Database registers of student personal profiles"
    },
    "/teachers/{teacherId}": {
      "schema": "Teacher",
      "description": "Database registers of educator professional profiles"
    },
    "/attendance/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Persistent attendance records by student-date"
    },
    "/assessments/{assessmentId}": {
      "schema": "StudentAssessment",
      "description": "Enforcement sheets of student academic scores, curriculum rankings, remarks, and positions"
    },
    "/users/{userId}": {
      "schema": "UserAccount",
      "description": "Credentials reference index holding roles for Admins and Headteachers"
    },
    "/fees/{feeId}": {
      "schema": "StudentFeeBill",
      "description": "Student fee bills and historical payment installments details"
    },
    "/paystack_payments/{paymentId}": {
      "schema": "PaystackPayment",
      "description": "Log of verified webhook and client transactions initiated via Paystack"
    },
    "/staff_attendance/{recordId}": {
      "schema": "StaffAttendanceRecord",
      "description": "Daily attendance mark and times for a teacher/staff member"
    },
    "/teacher_headteacher_sync/{syncId}": {
      "schema": "SyncEvent",
      "description": "Real-time teacher to headteacher synchronization events"
    },
    "/settings/{settingId}": {
      "schema": "AcademicCalendarConfig",
      "description": "System-wide academic configurations including active year and terms"
    },
    "/emis/{emisId}": {
      "schema": "EmisData",
      "description": "Ministry of Education / GES standard aligned EMIS school census documents"
    }
  }
}
